---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import albertoon from '../assets/albertoon.webp';
---

<header class="paper">
  <div class="container">
    <nav class="padding-small flex align-center space-between">

      <!-- Navigation Links -->
      <div class="flex gap-small align-center">
        <HeaderLink href="/" class="paper-btn btn-small flex align-center" style="gap: 8px;">
          <img src={albertoon.src} alt="Alberto Rojas" width="24" height="24" style="border-radius: 50%;" />
          Blog
        </HeaderLink>
        <HeaderLink href="/about" class="paper-btn btn-small">About me</HeaderLink>
      </div>

    </nav>
  </div>
</header>

